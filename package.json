{
  "name": "hydrawise-api",
  "version": "2.0.0",
  "description": "Library for accessing the Hydrawise API via the cloud or directly on the local network",
  "repository": {
    "type": "git",
    "url": "https://github.com/martijndierckx/hydrawise-api.git"
  },
  "homepage": "https://github.com/martijndierckx/hydrawise-api#readme",
  "bugs": {
    "url": "https://github.com/martijndierckx/hydrawise-api/issues"
  },
  "main": "dist/index.js",
  "type": "commonjs",
  "types": "./dist/index.d.ts",
  "keywords": [
    "hydrawise",
    "api",
    "iot",
    "sprinklers",
    "hunter",
    "hunter industries"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "npm test && npm run build",
    "postpublish": "npm run clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "contributors": [
    "Martijn Dierckx",
    "Paul Molluzzo (https://paul.molluzzo.com)"
  ],
  "license": "MIT",
  "engines": {
    "node": "^18.20.0 || ^20.18.0 || ^22.12.0 || ^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@vitest/coverage-v8": "^4.1.8",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
